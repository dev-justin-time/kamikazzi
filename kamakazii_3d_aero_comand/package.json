{
  "name": "kamikazzi-3d",
  "version": "1.0.0",
  "private": true,
  "description": "High-octane technical flight simulation through procedural neon valleys. Built with Three.js and Puter.js cloud integration.",
  "keywords": [
    "game",
    "three.js",
    "webgl",
    "flight",
    "arcade",
    "puter"
  ],
  "author": "Kamikazzi Team",
  "license": "MIT",
  "scripts": {
    "start": "python -m http.server 8765",
    "serve": "python -m http.server 8765",
    "dev": "python -m http.server 8765",
    "tailwind:build": "npx tailwindcss -i ./styles/tailwind-input.css -o ./styles/tailwind.css --minify",
    "tailwind:watch": "npx tailwindcss -i ./styles/tailwind-input.css -o ./styles/tailwind.css --watch"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "tailwindcss": "^3.4.19"
  }
}
