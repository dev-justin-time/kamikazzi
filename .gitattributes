# Auto detect text files and normalise line endings to LF
* text=auto eol=lf

# Source code — always LF
*.js    text eol=lf
*.mjs   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.rs    text eol=lf
*.rhai  text eol=lf
*.go    text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.svg   text eol=lf

# Windows-specific — CRLF
*.bat   text eol=crlf
*.ps1   text eol=crlf
*.cmd   text eol=crlf

# Binary files — no transformations
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.wav   binary
*.mp3   binary
*.ogg   binary
*.glb   binary
*.gltf  binary
*.bin   binary
*.wasm  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.zip   binary
*.gz    binary
*.tar   binary

# Lock files — keep as-is (don't normalise)
package-lock.json -diff
Cargo.lock        -diff
